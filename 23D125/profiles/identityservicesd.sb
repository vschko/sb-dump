	(syscall-number-bitmask-regex exit | fork | read | write | open | sys_close | link | unlink | chmod | chown | getuid | geteuid | recvmsg | sendmsg | recvfrom | accept | getpeername | getsockname | access | chflags | fchflags | sync | kill | sys_dup | pipe | sigaction | getgid | sigprocmask | sigpending | sigaltstack | ioctl | readlink | munmap | madvise | sys_fcntl | select | fsync | socket | connect | bind | setsockopt | listen | sigsuspend | getsockopt | readv | writev | fchown | fchmod | rename | mkfifo | sendto | shutdown | socketpair | mkdir | rmdir | utimes | futimes | pread | pwrite | statfs | fstatfs | quotactl | csops | csops_audittoken | kdebug_trace64 | sigreturn | stat | sys_fstat | lstat | pathconf | mmap | lseek | ftruncate | sysctl | open_dprotected_np | openat_dprotected_np | getattrlist | setattrlist | fgetattrlist | fsetattrlist | fgetxattr | setxattr | fsetxattr | removexattr | fremovexattr | listxattr | flistxattr | fsctl | ffsctl | shm_open | sys_sysctlbyname | stat_extended | lstat_extended | sys_fstat_extended | chmod_extended | fchmod_extended | mkdir_extended | psynch_rw_longrdlock | psynch_rw_yieldwrlock | psynch_rw_downgrade | psynch_rw_upgrade | psynch_mutexwait | psynch_mutexdrop | psynch_cvbroad | psynch_cvsignal | psynch_cvwait | psynch_rw_rdlock | psynch_rw_wrlock | psynch_rw_unlock | psynch_rw_unlock2 | psynch_cvclrprepost | iopolicysys | issetugid | __pthread_kill | __pthread_sigmask | __sigwait | __disable_threadsignal | __pthread_markcancel | __pthread_canceled | proc_info | stat64 | sys_fstat64 | lstat64 | stat64_extended | lstat64_extended | sys_fstat64_extended | getdirentries64 | statfs64 | fstatfs64 | __pthread_chdir | __pthread_fchdir | bsdthread_create | bsdthread_terminate | kqueue | kevent | lchown | bsdthread_register | workq_kernreturn | kevent64 | kevent_qos | kevent_id | __mac_syscall | pselect | pselect_nocancel | read_nocancel | write_nocancel | open_nocancel | sys_close_nocancel | wait4_nocancel | recvmsg_nocancel | sendmsg_nocancel | recvfrom_nocancel | sys_fcntl_nocancel | select_nocancel | connect_nocancel | sigsuspend_nocancel | readv_nocancel | writev_nocancel | sendto_nocancel | pread_nocancel | pwrite_nocancel | __sigwait_nocancel | sys_fileport_makeport | sys_fileport_makefd | guarded_open_np | guarded_close_np | guarded_kqueue_np | change_fdguard_np | connectx | clonefileat | openat | openat_nocancel | faccessat | fchmodat | fchownat | fstatat | fstatat64 | linkat | unlinkat | mkdirat | bsdthread_ctl | recvmsg_x | sendmsg_x | csrctl | guarded_open_dprotected_np | guarded_write_np | guarded_pwrite_np | guarded_writev_np | persona | getentropy | necp_open | necp_client_action | __nexus_open | __nexus_register | __nexus_deregister | __nexus_create | __nexus_destroy | __nexus_get_opt | __nexus_set_opt | __channel_open | __channel_get_info | __channel_sync | __channel_get_opt | __channel_set_opt | sys_ulock_wait | sys_ulock_wake | fclonefileat | necp_session_open | necp_session_action | kqueue_workloop_ctl | sys_preadv | sys_pwritev | sys_preadv_nocancel | sys_pwritev_nocancel | sys_ulock_wait2))
(allow syscall-mach
	(machtrap-number-bitmask-regex MSC__kernelrpc_mach_vm_purgable_control_trap | MSC__kernelrpc_mach_vm_purgable_control_trap | MSC__kernelrpc_mach_vm_purgable_control_trap | machtrap_number_17 | MSC__kernelrpc_mach_port_mod_refs_trap | MSC__kernelrpc_mach_port_deallocate_trap | MSC__kernelrpc_mach_port_mod_refs_trap | MSC_thread_self_trap | MSC_thread_self_trap | MSC_thread_self_trap | MSC_semaphore_signal_all_trap | MSC_semaphore_signal_trap | MSC_semaphore_signal_trap | MSC_mach_generate_activity_id | MSC__kernelrpc_mach_port_unguard_trap | MSC__kernelrpc_mach_port_unguard_trap | MSC_macx_swapoff | MSC_pfz_exit | MSC_pfz_exit | machtrap_number_65 | machtrap_number_73 | machtrap_number_75 | MSC_mach_wait_until | MSC_mk_timer_create | MSC_mk_timer_create | MSC_mach_timebase_info_trap | machtrap_number_97))
(allow syscall-mig
	(cc 6305 4298 8e89))
(delegate (with no-report) sysctl*)
(allow sysctl-read
	(sysctl-name "net.link.generic.system.flow_key_trace"))
(delegate (with no-report) sysctl-write)
(delegate (with no-report) system*)
(delegate (with no-report) system-acct)
(delegate (with no-report) system-audit)
(delegate (with no-report) system-automount)
(delegate (with no-report) system-debug)
(allow system-fcntl)
(delegate (with no-report) system-info)
(deny system-kas-info)
(delegate (with no-report) system-kext*)
(delegate (with no-report) system-kext-load)
(delegate (with no-report) system-kext-unload)
(delegate (with no-report) system-kext-query)
(delegate (with no-report) system-mac*)
(delegate (with no-report) system-mac-label)
(allow system-mac-syscall)
(allow system-memorystatus-control)
(allow system-necp-client-action)
(delegate (with no-report) system-nfssvc)
(delegate (with no-report) system-package-check)
(allow system-privilege)
(delegate (with no-report) system-reboot)
(delegate (with no-report) system-sched)
(delegate (with no-report) system-set-time)
(delegate (with no-report) system-suspend-resume)
(delegate (with no-report) system-swap)
(delegate (with no-report) user-preference*)
(allow user-preference-read
	(preference-domain "com.apple.migration")
	(preference-domain "com.apple.AppSupport")
	(preference-domain "com.apple.imessage")
	(preference-domain "com.apple.DataMigration")
	(preference-domain "com.apple.apsd")
	(preference-domain "com.apple.logging")
	(preference-domain "com.apple.CloudKit")
	(preference-domain "com.apple.CFNetwork")
	(require-any (preference-domain "com.apple.identityservices.idstatuscache")
(preference-domain "com.apple.identityservices.serviceDisablement")
(preference-domain "com.apple.ids.deviceproperties")
(preference-domain "com.apple.ids.subservices")
(preference-domain "com.apple.ids.service.com.apple.private.alloy.location.stream"))
	(preference-domain "com.apple.demo-settings")
	(preference-domain "com.apple.purplebuddy.notbackedup")
	(preference-domain "com.apple.carrier")
	(require-any (preference-domain "com.apple.jett.switch-icloud")
(preference-domain "com.apple.ids.service.com.apple.private.alloy.otaupdate"))
	(preference-domain "com.apple.NanoRegistry")
	(preference-domain "com.apple.imessage.bag")
	(preference-domain "com.apple.Messages")
	(preference-domain "com.apple.registration")
	(preference-domain "com.apple.persistentconnection")
	(preference-domain "com.apple.CloudSubscriptionFeatures.cache")
	(preference-domain "com.apple.ids")
	(preference-domain "com.apple.ids.debug")
	(preference-domain "com.apple.purplebuddy")
	(preference-domain "com.apple.facetime.bag")
	(preference-domain "com.apple.conference")
	(preference-domain "com.apple.pairedsync")
	(preference-domain "com.apple.marco")
	(preference-domain "com.apple.identityservicesd"))
(allow user-preference-write
	(preference-domain "com.apple.DataMigration")
	(require-any (preference-domain "com.apple.identityservices.idstatuscache")
(preference-domain "com.apple.identityservices.serviceDisablement")
(preference-domain "com.apple.ids.deviceproperties")
(preference-domain "com.apple.ids.subservices")
(preference-domain "com.apple.ids.service.com.apple.private.alloy.location.stream"))
	(preference-domain "com.apple.imessage.bag")
	(preference-domain "com.apple.ids")
	(preference-domain "com.apple.ids.debug")
	(preference-domain "com.apple.facetime.bag")
	(preference-domain "com.apple.conference")
	(preference-domain "com.apple.identityservicesd"))
(deny storage-class-map)
(allow process-exec-update-label)
