(version 1)
(delegate (with no-report) default)
(delegate (with no-report) appleevent-send)
(delegate (with no-report) authorization-right-obtain)
(delegate (with no-report) boot-arg-set)
(allow consume-extension)
(delegate (with no-report) device*)
(delegate (with no-report) device-camera)
(delegate (with no-report) device-microphone)
(allow darwin-notification-post)
(delegate (with no-report) distributed-notification-post)
(allow dynamic-code-generation)
(delegate (with no-report) file*)
(delegate (with no-report) file-chroot)
(allow file-clone)
(allow file-ioctl
	(literal "/dev/aes_0")
	(literal "/dev/bpf")
	(literal "/dev/dtracehelper"))
(allow file-issue-extension
	(require-all
		(require-any (subpath "/private/preboot/Cryptexes")
(subpath "/System/Cryptexes"))
		(extension-class "com.apple.app-sandbox.read")))
(allow file-link)
(allow file-lock)
(allow file-map-executable
	(subpath "/usr/appleinternal/lib/sanitizers")
	(require-any (subpath "/private/preboot/Cryptexes")
(subpath "/System/Cryptexes")))
(delegate (with no-report) file-mknod)
(delegate (with no-report) file-mount)
(delegate (with no-report) file-mount-update)
(allow file-read*
	(literal "/private")
	(require-any (literal "/private/preboot/cryptex1/current/SystemVersion.plist")
(literal "/private/preboot/cryptex1/current/RestoreVersion.plist"))
	(literal "/Library/Preferences/com.apple.networkextension.uuidcache.plist")
	(literal)
	(require-any (subpath "/private/var/tmp/com.apple.mDNSResponder")
(subpath-prefix "${PROCESS_TEMP_DIR}/com.apple.mDNSResponder"))
	(require-any (subpath "/private/preboot/Cryptexes")
(subpath "/System/Cryptexes"))
	(require-any (literal "/System")
(literal "/private/preboot"))
	(literal "/")
	(subpath "/usr/appleinternal/lib/sanitizers")
	(literal "/private/var/preferences/com.apple.networkd.plist")
	(require-any (regex #"/private/var/folders/[UNSUPPORTED]+/[UNSUPPORTED]+/C/mds/?")
(regex #"/private/var/folders/[UNSUPPORTED]+/[UNSUPPORTED]+/-Caches-/mds/?"))
	(literal "/Library/Preferences/com.apple.networkd.plist")
	(literal "/dev/zero")
	(subpath "/private/var/log/mDNSResponder")
	(literal "/private/var/db/DarwinDirectory/local/recordStore.data")
	(literal "/private/var/db/com.apple.networkextension.tracker-info")
	(literal "/private/var/run/mDNSResponder")
	(literal "/dev/random")
	(literal "/dev/null")
	(literal "/dev/aes_0")
	(literal "/dev/urandom")
	(literal "/private/var/tmp/mDNSResponder")
	(literal "/dev/dtracehelper")
	(require-all
		(file-mode #o0004)
		(require-any
			(subpath "/usr/lib")
			(subpath "/usr/share")
			(subpath "/System")))
	(require-all
		(literal "/private/var/tmp/mds/")
		(regex #"^/private/var/tmp/mds/[0-9]+/" #"^/private/var/tmp/mds/[0-9]+$"))
	(require-all
		(literal "/private/var/db/mds/")
		(require-any
			(extension com.apple.app-sandbox.read)
			(regex #"^/private/var/db/mds/[0-9]+/" #"^/private/var/db/mds/[0-9]+$")
			(extension com.apple.security.exception.files.absolute-path.read-only)
			(extension com.apple.security.exception.files.absolute-path.read-write)
			(extension com.apple.app-sandbox.read-write)
			(require-all
				(require-any (subpath "/private/var/hardware/FactoryData")
(literal "/usr/standalone/firmware/apticket.der"))
				(require-any (literal "/System/Library/Caches/apticket.der")
(subpath "/System/Library/Caches/com.apple.factorydata")
(subpath "/System/Library/Caches/com.apple.kernelcaches"))))))
(allow file-read-data
	(require-any (subpath "/private/var/tmp/mds")
(literal "/private/var/db/crls/crlcache.db")
(literal "/Library/Keychains/System.keychain"))
	(subpath "/private/var/db/mds")
	(require-all
		(require-not (literal "/Library/Keychains/"))
		(require-any
			(literal "/private/var/preferences/com.apple.networkd.plist")
			(require-any (subpath "/AppleInternal/Library/Preferences/Logging")
(literal "/usr/sbin/mDNSResponder")
(literal "/private/etc")
(literal "/private/var/Managed Preferences/mobile/com.apple.mDNSResponder.plist")
(literal "/private/var/mobile/Library/com.apple.DeviceAccess/DANetworkUUIDs.plist")
(literal "/Library/Security/Trust Settings/Admin.plist")
(literal "/Library/Preferences/.GlobalPreferences.")
(subpath "/Library/Preferences/Logging")
(literal "/Library/Preferences/ByHost/.GlobalPreferences.")
(literal "/Library/Preferences/com.apple.security.")
(literal "/Library/Preferences/com.apple.crypto.plist")
(literal "/Library/Preferences/com.apple.mDNSResponder.plist")
(literal "/Library/Preferences/SystemConfiguration/preferences.plist")
(literal "/Library/Preferences/SystemConfiguration/com.apple.nat.plist")
(literal "/Library/Preferences/SystemConfiguration/com.apple.PowerManagement.plist"))
			(literal "/dev/console")
			(literal "/usr/sbin")
			(subpath "/private/var/preferences/Logging")
			(literal "/private/etc/hosts")
			(subpath "/System/Library/Preferences/Logging")
			(literal "/private/var/preferences/SystemConfiguration/preferences.plist")
			(subpath "/private/var/db/timezone"))))
(allow file-read-metadata)
(delegate (with no-report) file-revoke)
(delegate (with no-report) file-search)
(allow file-test-existence)
(delegate (with no-report) file-unmount)
(allow file-write*
	(literal "/private/var/tmp/mDNSResponder")
	(subpath "/private/var/log/mDNSResponder")
	(require-any (regex #"/private/var/folders/[UNSUPPORTED]+/[UNSUPPORTED]+/C/mds/?")
(regex #"/private/var/folders/[UNSUPPORTED]+/[UNSUPPORTED]+/-Caches-/mds/?"))
	(require-any (subpath "/private/var/tmp/com.apple.mDNSResponder")
(subpath-prefix "${PROCESS_TEMP_DIR}/com.apple.mDNSResponder"))
	(literal "/private/var/run/mDNSResponder")
	(file-mode #o0000)
	(require-all
		(literal "/private/var/tmp/mds/")
		(regex #"^/private/var/tmp/mds/[0-9]+/" #"^/private/var/tmp/mds/[0-9]+$"))
	(require-all
		(literal "/private/var/db/mds/")
		(regex #"^/private/var/db/mds/[0-9]+/" #"^/private/var/db/mds/[0-9]+$")))
(allow file-write-data
	(literal "/dev/null")
	(literal "/dev/aes_0")
	(literal "/dev/dtracehelper")
	(literal "/dev/zero")
	(literal "/dev/console"))
(deny file-write-setugid)
(allow file-write-unlink
	(entitlement-is-present com.apple.private.oop-jit.loader)
	(require-all
		(extension com.apple.sandbox.oopjit)
		(subpath "/private/var/OOPJit")))
(allow fs-quota*)
(allow fs-quota-get)
(allow fs-quota-on)
(allow fs-quota-off)
(allow fs-quota-set*)
(allow fs-quota-set-limits)
(allow fs-quota-set-usage)
(allow fs-quota-stat)
(allow fs-quota-sync)
(delegate (with no-report) fs-rename)
(delegate (with no-report) fs-snapshot*)
(delegate (with no-report) fs-snapshot-create)
(delegate (with no-report) fs-snapshot-delete)
(allow fs-snapshot-mount)
(delegate (with no-report) fs-snapshot-revert)
(delegate (with no-report) generic-issue-extension)
(delegate (with no-report) qtn-user)
(delegate (with no-report) hid-control)
(delegate (with no-report) iokit*)
(allow iokit-get-properties)
(delegate (with no-report) iokit-issue-extension)
(delegate (with no-report) iokit-open*)
(allow iokit-open-user-client
	(require-any (iokit-user-client-class "mDNSOffloadUserClient")
(iokit-user-client-class "wlDNSOffloadUserClient")
(iokit-user-client-class "NVEthernetUserClientMDNS"))
	(iokit-user-client-class "IO80211APIUserClient")
	(iokit-user-client-class "AppleMobileFileIntegrityUserClient")
	(iokit-user-client-class "RootDomainUserClient"))
(allow iokit-open-service)
(delegate (with no-report) iokit-set-properties)
(delegate (with no-report) ipc*)
(delegate (with no-report) ipc-posix*)
(delegate (with no-report) ipc-posix-sem*)
(delegate (with no-report) ipc-posix-sem-create)
(delegate (with no-report) ipc-posix-sem-open)
(delegate (with no-report) ipc-posix-sem-post)
(delegate (with no-report) ipc-posix-sem-unlink)
(delegate (with no-report) ipc-posix-sem-wait)
(allow ipc-posix-shm*)
(allow ipc-posix-shm-read-data)
(allow ipc-posix-shm-write*)
(allow ipc-posix-shm-write-create)
(allow ipc-posix-shm-write-data)
(allow ipc-posix-shm-write-unlink)
(delegate (with no-report) ipc-sysv*)
(delegate (with no-report) ipc-sysv-msg)
(delegate (with no-report) ipc-sysv-sem)
(delegate (with no-report) ipc-sysv-shm)
(deny job-creation)
(delegate (with no-report) mach*)
(allow mach-bootstrap)
(allow mach-cross-domain-lookup)
(allow mach-derive-port)
(delegate (with no-report) mach-host*)
(delegate (with no-report) mach-host-exception-port-set)
(delegate (with no-report) mach-host-special-port-set)
(delegate (with no-report) mach-issue-extension)
(allow mach-lookup
	(global-name "com.apple.securityd")
	(global-name "com.apple.SystemConfiguration.DNSConfiguration")
	(global-name "com.apple.SystemConfiguration.NetworkInformation")
	(global-name "com.apple.server.bluetooth.le.att.xpc")
	(global-name "com.apple.powerlog.plxpclogger.xpc")
	(require-any (global-name "com.apple.awacs")
(global-name "com.apple.webcontentfilter.dns")
(global-name "com.apple.mDNSResponder_Helper")
(global-name "com.apple.distributed_notifications.2")
(global-name "com.apple.server.bluetooth.general.xpc")
(global-name "com.apple.bluetoothd")
(global-name "com.apple.bsd.dirhelper"))
	(global-name "com.apple.SystemConfiguration.helper")
	(extension com.apple.security.exception.mach-lookup.local-name)
	(global-name "com.apple.system.notification_center")
	(extension com.apple.security.exception.mach-lookup.global-name)
	(global-name "com.apple.CoreServices.coreservicesd")
	(global-name "com.apple.wifip2pd")
	(global-name "com.apple.DeviceAccess.xpc")
	(global-name "com.apple.SystemConfiguration.configd")
	(global-name "com.apple.wifi.manager")
	(global-name "com.apple.cfnetwork.cfnetworkagent")
	(global-name "com.apple.StatusKit.presence")
	(global-name "com.apple.nehelper")
	(global-name "com.apple.nesessionmanager")
	(global-name "com.apple.system.logger")
	(global-name "com.apple.dnssd.service")
	(global-name "com.apple.coreservices.quarantine-resolver")
	(global-name "com.apple.ocspd")
	(global-name "com.apple.usymptomsd")
	(global-name "com.apple.trustd")
	(global-name "com.apple.analyticsd")
	(global-name "com.apple.server.bluetooth")
	(global-name "com.apple.nesessionmanager.content-filter")
	(global-name "com.apple.awdd")
	(global-name "com.apple.SecurityServer")
	(global-name "com.apple.mDNSResponderHelper")
	(global-name "com.apple.mobilegestalt.xpc")
	(global-name "com.apple.PowerManagement.control")
	(global-name "com.apple.lsd.mapdb")
	(global-name "com.apple.distributed_notifications@1v3")
	(global-name "com.apple.networkd_privileged")
	(global-name "com.apple.cfnetwork.AuthBrokerAgent")
	(global-name "com.apple.SystemConfiguration.SCNetworkReachability")
	(require-all
		(require-not (xpc-service-name "com.apple.WebKit."))
		(require-any
			(global-name "com.apple.diagnosticd")
			(global-name "com.apple.system.DirectoryService.libinfo_v1")
			(require-any (global-name "com.apple.cfprefsd.daemon")
(global-name "com.apple.cfprefsd.daemon.system"))
			(global-name "com.apple.cfprefsd.agent")
			(global-name "com.apple.logd")
			(xpc-service-name-regex #".+")
			(local-name "com.apple.cfprefsd.agent")
			(global-name "com.apple.lsd.openurl")
			(global-name "com.apple.tccd")
			(global-name "com.apple.lsd.advertisingidentifiers"))))
(delegate (with no-report) mach-priv*)
(delegate (with no-report) mach-priv-host-port)
(delegate (with no-report) mach-priv-task-port)
(allow mach-register
	(global-name "com.apple.d2d.ipc"))
(delegate (with no-report) mach-task*)
(allow mach-task-exception-port-set)
(allow mach-task-special-port*)
(allow mach-task-special-port-get)
(allow mach-task-special-port-set)
(allow necp-client-open)
(allow network*)
(allow network-inbound)
(allow network-bind)
(allow network-outbound)
(allow nvram*)
(allow nvram-delete)
(allow nvram-get)
(allow nvram-set)
(delegate (with no-report) opendirectory-user-modify)
(delegate (with no-report) process*)
(allow process-codesigning)
(delegate (with no-report) process-exec*)
(delegate (with no-report) process-exec-interpreter)
(delegate (with no-report) process-fork)
(allow process-info*)
(allow process-info-codesignature)
(allow process-info-dirtycontrol)
(allow process-info-ledger)
(allow process-info-listpids)
(allow process-info-pidinfo)
(allow process-info-pidfdinfo)
(allow process-info-pidfileportinfo)
(allow process-info-rusage)
(delegate (with no-report) process-info-sandbox-container)
(allow process-info-setcontrol)
(allow process-iopolicy*)
(allow process-iopolicy-get)
(allow process-iopolicy-set)
(delegate (with no-report) process-legacy-codesigning*)
(delegate (with no-report) process-legacy-codesigning-blob-get)
(delegate (with no-report) process-legacy-codesigning-cdhash-get)
(delegate (with no-report) process-legacy-codesigning-entitlements-blob-get)
(delegate (with no-report) process-legacy-codesigning-entitlements-der-blob-get)
(delegate (with no-report) process-legacy-codesigning-identity-get)
(delegate (with no-report) process-legacy-codesigning-status*)
(delegate (with no-report) process-legacy-codesigning-status-get)
(delegate (with no-report) process-legacy-codesigning-status-set)
(delegate (with no-report) process-legacy-codesigning-teamid-get)
(delegate (with no-report) process-legacy-codesigning-text-offset-get)
(delegate (with no-report) pseudo-tty)
(allow sandbox-check)
(allow socket-ioctl)
(delegate (with no-report) socket-option*)
(allow socket-option-get)
(allow socket-option-set)
(delegate (with no-report) syscall*)
(allow syscall-unix)
(allow syscall-mach)
(allow syscall-mig)
(allow sysctl*
	(sysctl-name "net.inet.tcp.info"))
(allow sysctl-read)
(delegate (with no-report) system*)
(delegate (with no-report) system-acct)
(delegate (with no-report) system-audit)
(delegate (with no-report) system-automount)
(delegate (with no-report) system-debug)
(allow system-fcntl)
(delegate (with no-report) system-fsctl)
(deny system-kas-info)
(delegate (with no-report) system-kext*)
(delegate (with no-report) system-kext-load)
(delegate (with no-report) system-kext-unload)
(delegate (with no-report) system-kext-query)
(delegate (with no-report) system-mac*)
(delegate (with no-report) system-mac-label)
(allow system-mac-syscall)
(allow system-memorystatus-control)
(allow system-necp-client-action)
(delegate (with no-report) system-nfssvc)
(delegate (with no-report) system-package-check)
(allow system-privilege)
(delegate (with no-report) system-reboot)
(delegate (with no-report) system-sched)
(delegate (with no-report) system-set-time)
(allow system-socket)
(delegate (with no-report) system-suspend-resume)
(delegate (with no-report) system-swap)
(delegate (with no-report) user-preference*)
(allow user-preference-read
	(preference-domain "com.apple.mDNSResponder"))
(delegate (with no-report) user-preference-write)
(deny storage-class-map)
(allow process-exec-update-label)
