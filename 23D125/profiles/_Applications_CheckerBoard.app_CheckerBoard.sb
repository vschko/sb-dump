(version 1)
(allow default)
(deny file-ioctl)
(deny generic-issue-extension)
(deny iokit-issue-extension)
(deny iokit-open-user-client
	(require-all
		(require-not (iokit-user-client-class "IOUserUserClient"))
		(require-not (iokit-user-client-class "IOGPUDeviceUserClient"))
		(require-not (iokit-user-client-class "IOAESAcceleratorUserClient"))
		(require-not (iokit-user-client-class "RootDomainUserClient"))
		(require-not (iokit-user-client-class "IOSurfaceRootUserClient"))
		(require-not (iokit-user-client-class "IO80211APIUserClient"))
		(require-not (iokit-user-client-class "IOMobileFramebufferUserClient"))))
(deny iokit-open-service
	(require-all
		(require-not (iokit-user-client-class "AppleKeyStore"))
		(require-not (iokit-user-client-class "IOSurfaceRoot"))
		(require-not (iokit-user-client-class "AppleParavirtGPU"))
		(require-not (iokit-user-client-class "IOUserNetworkWLAN"))
		(require-not (iokit-user-client-class "AppleS8000AESAccelerator"))
		(require-not (iokit-user-client-class "IOMobileFramebuffer"))
		(require-not (iokit-user-client-class "AppleCredentialManager"))
		(require-not (iokit-user-client-class "IOPMrootDomain"))
		(iokit-user-client-class "AppleANS2CGNVMeController")
		(iokit-user-client-class "AGXAccelerator")))
(deny iokit-set-properties
	(require-not (iokit-user-client-class "IOPMrootDomain"))
	(require-all
		(require-all (require-not (iokit-property "SleepDisabled"))
(require-not (iokit-property "System Idle Seconds")))
		(require-not (iokit-property "System Boot Complete"))))
(deny ipc*)
(deny ipc-posix*)
(deny ipc-posix-sem*)
(deny ipc-posix-sem-create
	(require-not (ipc-posix-name "keyboard-flush.boot")))
(deny ipc-posix-sem-open
	(require-not (ipc-posix-name "keyboard-flush.boot")))
(deny ipc-posix-sem-post)
(deny ipc-posix-sem-unlink)
(deny ipc-posix-sem-wait)
(deny ipc-posix-shm*)
(deny ipc-posix-shm-read-data
	(require-all
		(require-not (ipc-posix-name "apple.shm.notification_center"))
		(require-not (ipc-posix-name "apple.cfprefs.daemonv1"))
		(require-not (ipc-posix-name "apple.cfprefs.system.daemonv1"))
		(require-not (ipc-posix-name "apple.cfprefs.user.daemonv1"))
		(require-all (require-not (ipc-posix-name "/FBW1:com.apple.frontboard.syst"))
(require-not (ipc-posix-name "/FBW2:com.apple.frontboard.syst")))))
(deny ipc-posix-shm-write*)
(deny ipc-posix-shm-write-create
	(require-any (ipc-posix-name "/FBW1:com.apple.frontboard.syst")
(ipc-posix-name "/FBW2:com.apple.frontboard.syst")))
(deny ipc-posix-shm-write-data)
(deny ipc-sysv*)
(deny ipc-sysv-msg)
(deny ipc-sysv-sem)
(deny ipc-sysv-shm)
(deny job-creation)
(deny mach-issue-extension)
(deny mach-lookup
