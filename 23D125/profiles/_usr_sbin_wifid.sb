(require-not (iokit-property "line"))
(require-not (iokit-property "assertId"))
(require-not (iokit-property "sunrise-wifi-occal"))
(require-not (iokit-property "file"))
(require-not (iokit-property "function"))
(require-not (iokit-property "title_str"))
(require-not (iokit-property "title_size")))
		(require-all (require-not (iokit-property "sunrise-bt-bcal"))
(require-not (iokit-property "sunrise-wifi-wcal"))
(require-not (iokit-property "sunrise-wifi-oca2"))
(require-not (iokit-property "sunrise-wifi-ocal")))))
