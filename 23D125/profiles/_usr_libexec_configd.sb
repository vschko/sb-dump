(version 1)
(allow default)
(deny file-ioctl
	(require-all
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "B" 123)))
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "B" 112)))
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "B" 108)))
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "B" 103)))
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "i" 26)))
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "B" 117)))
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "B" 102)))))
(deny generic-issue-extension)
(deny iokit-issue-extension)
(deny iokit-open-user-client
	(require-all
		(require-not (iokit-user-client-class "IOUserUserClient"))
		(require-not (iokit-user-client-class "RootDomainUserClient"))
		(require-not (iokit-user-client-class "IONetworkStackUserClient"))
		(require-not (iokit-user-client-class "IO80211APIUserClient"))))
(deny iokit-open-service
	(require-all
		(require-not (iokit-user-client-class "AppleBCMWLANSkywalkInterface"))
		(require-not (iokit-user-client-class "IOUserNetworkWLAN"))
		(require-not (iokit-user-client-class "IONetworkStack"))
		(require-all (require-not (iokit-user-client-class "AppleBCMWLANNANDataInterface"))
(require-not (iokit-user-client-class "AppleBCMWLANProximityInterface")))
		(require-not (iokit-user-client-class "IOUserNetworkEthernet"))
		(require-not (iokit-user-client-class "IOPMrootDomain"))))
(deny iokit-set-properties
	(require-all (require-not (iokit-user-client-class "IOUSBDeviceController"))
(require-not (iokit-user-client-class "AppleNubSynopsysOTGDevice")))
	(require-all (require-not (iokit-property "USBDeviceCommand"))
(require-not (iokit-property "USBDeviceCommandParameter")))
	(require-all
		(iokit-user-client-class "IONetworkStackUserClient")
		(require-all (require-not (iokit-property "IOInterfaceUnit"))
(require-not (iokit-property "IORegistryEntryID"))
(require-not (iokit-property "IONetworkStackUserCommand")))))
(deny ipc*)
(deny ipc-posix*)
(deny ipc-posix-sem*)
(deny ipc-posix-sem-create
	(require-not (ipc-posix-name "com.apple.configd.first-boot")))
(deny ipc-posix-sem-open
	(require-not (ipc-posix-name "purplebuddy.sentinel")))
(deny ipc-posix-sem-post)
(deny ipc-posix-sem-unlink)
(deny ipc-posix-sem-wait)
(deny ipc-posix-shm*)
(deny ipc-posix-shm-write*)
(deny ipc-posix-shm-write-create)
(deny ipc-posix-shm-write-data)
(deny ipc-posix-shm-write-unlink)
(deny ipc-sysv*)
(deny ipc-sysv-msg)
(deny ipc-sysv-sem)
(deny ipc-sysv-shm)
(deny job-creation)
(deny mach-issue-extension)
