(allow file-read*
	(subpath-prefix "${HOME}/Library/Fonts")
	(subpath "/private/var/MobileAsset/Assets/com_apple_MobileAsset_LinguisticData")
	(literal-prefix "${HOME}/Library/PPTDevice")
	(subpath-prefix "${HOME}/Library/Caches/com.apple.MobileSMS")
