				(require-all (require-not (xpc-service-name "com.apple.MessagesAirlockService"))
(require-not (xpc-service-name "com.apple.MessagesBlastDoorService")))
				(require-not (extension com.apple.pluginkit.plugin-service)))
			(require-all
				(global-name "com.apple.AppSSO.service-xpc")
				(require-any
					(xpc-service-name-regex #".+")
					(require-all
						(debug-mode)
						(global-name "com.apple.dt.testmanagerd.uiprocess")))))))
(deny process-exec*)
(deny process-exec-interpreter)
(deny syscall-unix
