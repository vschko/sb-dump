(deny ipc-sysv-sem)
(deny ipc-sysv-shm)
(deny job-creation)
(deny mach-issue-extension)
(deny mach-lookup
	(require-all
		(require-not (global-name "com.apple.securityd"))
		(require-all (require-not (global-name "com.apple.idcredd.storage.xpc"))
(require-not (global-name "com.apple.idcredd.biometrics.xpc")))
		(require-not (global-name "com.apple.diagnosticd"))
