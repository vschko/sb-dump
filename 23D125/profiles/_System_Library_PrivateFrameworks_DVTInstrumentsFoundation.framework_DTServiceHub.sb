(require-not (global-name "com.apple.preview-shell.host-shell-pipe-services"))
(require-not (global-name "com.apple.preview-shell.host-agent-pipe-services")))
		(require-not (global-name "com.apple.SystemConfiguration.configd"))
		(require-not (global-name "com.apple.mobile.heartbeat"))
