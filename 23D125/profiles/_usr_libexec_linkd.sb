(version 1)
(allow default)
(deny generic-issue-extension)
(deny iokit-issue-extension)
(deny iokit-set-properties)
(deny ipc*)
(deny ipc-posix*)
(deny ipc-posix-sem*)
(deny ipc-posix-sem-create)
(deny ipc-posix-sem-open)
(deny ipc-posix-sem-post)
(deny ipc-posix-sem-unlink)
(deny ipc-posix-sem-wait)
(deny ipc-posix-shm*)
(deny ipc-posix-shm-read-data)
(deny ipc-posix-shm-write*)
(deny ipc-posix-shm-write-create)
(deny ipc-posix-shm-write-data)
(deny ipc-posix-shm-write-unlink)
(deny ipc-sysv*)
(deny ipc-sysv-msg)
(deny ipc-sysv-sem)
(deny ipc-sysv-shm)
(deny job-creation)
(deny mach-issue-extension)
(deny mach-lookup
	(require-all
		(require-not (global-name "com.apple.diagnosticd"))
		(require-not (global-name "com.apple.logd.events"))
		(require-not (global-name "com.apple.runningboard"))
		(require-not (global-name "com.apple.mediaexperience.endpoint.xpc"))
		(require-all (require-not (global-name "com.apple.corespeech.corespeechd.uaapservice"))
(require-not (global-name "com.apple.remoteappintentsd.appevent"))
(require-not (global-name "com.apple.remoteappintentsd..appevent")))
		(require-not (global-name "com.apple.system.notification_center"))
		(require-not (global-name "com.apple.accountsd.accountmanager"))
		(require-not (global-name "com.apple.mobile.keybagd.UserManager.xpc"))
		(require-not (global-name "com.apple.debug.telemetry"))
		(require-not (global-name "com.apple.iapd.xpc"))
		(require-not (global-name "com.apple.system.libinfo.muser"))
		(require-not (global-name "com.apple.familycircle.agent"))
		(require-not (global-name "com.apple.system.logger"))
		(require-not (global-name "com.apple.diagd"))
		(require-any
			(require-all
				(xpc-service-name-regex #".+")
				(require-all (require-not (xpc-service-name "com.apple.HomeAppIntentsExtension"))
(require-not (xpc-service-name "com.apple.BreadBoardIntentsExtension"))
(require-not (xpc-service-name "com.apple.omniSearch.SearchToolExtension"))
(require-not (xpc-service-name "com.apple.NanoCalendar.FocusConfiguration"))
(require-not (xpc-service-name "com.apple.MobileAddressBook.ContactsAppIntentsExtension"))
(require-not (xpc-service-name "com.apple.intelligenceflow.IntelligenceFlowAppIntentsExtension"))
(require-not (xpc-service-name "com.apple.mobilemail.MailShortcutsExtension"))
(require-not (xpc-service-name "com.apple.mobilecal.FocusConfigurationExtension")))
				(require-not (extension com.apple.pluginkit.plugin-service)))
			(require-all
				(require-not (global-name "com.apple.mobile.usermanagerd.xpc"))
				(require-not (global-name "com.apple.siri.vocabularyupdates"))
				(require-not (global-name "com.apple.appprotectiond.guard"))
				(require-not (global-name "com.apple.accessories.externalaccessory-server"))
				(require-not (global-name "com.apple.analyticsd"))
				(require-not (global-name "com.apple.uservault"))
				(require-not (global-name "com.apple.backboard.hid.services"))
				(require-not (global-name "com.apple.airplay.endpoint.xpc"))
				(require-not (global-name "com.apple.siriknowledged.koa.donate"))
				(require-not (global-name "com.apple.appprotectiond.read"))
				(require-not (global-name "com.apple.iap2d.xpc"))
				(require-not (global-name "com.apple.linkd.extension"))
				(require-not (global-name "com.apple.cfprefsd.daemon"))
				(require-not (global-name "com.apple.lsd.mapdb"))
				(require-not (global-name "com.apple.distributed_notifications@1v3-debug"))
				(require-not (global-name "com.apple.distributed_notifications@1v3"))
				(require-not (global-name "com.apple.geod"))
				(require-not (global-name "com.apple.erm.logging"))
				(require-not (global-name "com.apple.duetactivityscheduler"))
				(require-not (global-name "com.apple.chronoservices"))
				(require-not (global-name "com.apple.logd"))
				(require-not (global-name "com.apple.coremedia.endpointremotecontrolsession.xpc"))
				(require-not (global-name "com.apple.containermanagerd"))
				(require-not (global-name "com.apple.containermanagerd.system"))
				(require-not (global-name "com.apple.frontboard.systemappservices"))
				(require-not (global-name "com.apple.cfprefsd.daemon.system"))
				(require-not (xpc-service-name "com.apple.intents.intents-helper"))
				(require-not (xpc-service-name "com.apple.extensionkitservice"))
				(require-not (xpc-service-name "com.apple.appintents.LiveEntityService"))
				(require-not (xpc-service-name "com.apple.SetStoreUpdateService"))
				(require-not (global-name "com.apple.DiskArbitration.diskarbitrationd"))
				(require-not (global-name "com.apple.CoreServices.coreservicesd"))
				(global-name "com.apple.CARenderServer")
				(require-any
					(xpc-service-name-regex #".+")
					(require-all
						(debug-mode)
						(global-name "com.apple.dt.testmanagerd.uiprocess")))))))
(deny process-exec*)
(deny process-exec-interpreter)
(deny socket-ioctl)
(deny syscall-unix
	(require-not (syscall-number-bitmask-regex exit | read | write | open | sys_close | unlink | getfsstat | getpid | getuid | geteuid | access | sys_crossarch_trap | sys_dup | getegid | sigaction | getgid | sigprocmask | sigpending | sigaltstack | ioctl | readlink | umask | msync | munmap | mprotect | madvise | sys_dup2 | sys_fcntl | fsync | socket | connect | sigsuspend | gettimeofday | readv | writev | sys_flock | sendto | mkdir | rmdir | pread | pwrite | csops | csops_audittoken | kdebug_typefilter | kdebug_trace_string | kdebug_trace64 | kdebug_trace | sigreturn | pathconf | getrlimit | setrlimit | mmap | lseek | ftruncate | sysctl | open_dprotected_np | openat_dprotected_np | getattrlist | getxattr | fgetxattr | fsctl | shm_open | sys_sysctlbyname | gettid | mkdir_extended | shared_region_check_np | psynch_mutexwait | psynch_mutexdrop | psynch_cvbroad | psynch_cvsignal | psynch_cvwait | psynch_rw_rdlock | psynch_rw_wrlock | psynch_rw_unlock | psynch_cvclrprepost | iopolicysys | issetugid | __pthread_kill | __pthread_sigmask | __sigwait | __disable_threadsignal | __pthread_canceled | __semwait_signal | proc_info | stat64 | sys_fstat64 | lstat64 | stat64_extended | lstat64_extended | sys_fstat64_extended | getdirentries64 | statfs64 | fstatfs64 | getfsstat64 | __pthread_chdir | __pthread_fchdir | bsdthread_create | bsdthread_terminate | kqueue | bsdthread_register | workq_open | workq_kernreturn | kevent_qos | kevent_id | __mac_syscall | read_nocancel | write_nocancel | open_nocancel | sys_close_nocancel | msync_nocancel | sys_fcntl_nocancel | fsync_nocancel | sigsuspend_nocancel | readv_nocancel | writev_nocancel | pread_nocancel | pwrite_nocancel | __sigwait_nocancel | __semwait_signal_nocancel | fsgetpath | sys_fileport_makeport | sys_fileport_makefd | memorystatus_control | guarded_open_np | guarded_close_np | guarded_kqueue_np | proc_rlimit_control | getattrlistbulk | openat | openat_nocancel | renameat | faccessat | fstatat | fstatat64 | unlinkat | mkdirat | bsdthread_ctl | guarded_open_dprotected_np | guarded_write_np | guarded_pwrite_np | renameatx_np | persona | getentropy | sys_ulock_wait | sys_ulock_wake | fclonefileat | abort_with_payload | os_fault_with_payload | kqueue_workloop_ctl | memorystatus_available_memory | objc_bp_assist_cfg_np | sys_preadv | sys_preadv_nocancel | sys_ulock_wait2 | proc_info_extended_id | map_with_linking_np)))
(deny syscall-mach
	(require-not (machtrap-number-bitmask-regex MSC__kernelrpc_mach_vm_purgable_control_trap | MSC__kernelrpc_mach_vm_purgable_control_trap | MSC__kernelrpc_mach_vm_purgable_control_trap | machtrap_number_17 | MSC__kernelrpc_mach_port_mod_refs_trap | MSC__kernelrpc_mach_port_deallocate_trap | machtrap_number_17 | MSC_thread_self_trap | MSC_thread_self_trap | MSC_thread_self_trap | MSC_semaphore_signal_all_trap | MSC_semaphore_signal_trap | MSC_semaphore_signal_trap | MSC__kernelrpc_mach_port_unguard_trap | MSC__kernelrpc_mach_port_unguard_trap | MSC__kernelrpc_mach_port_guard_trap | MSC__kernelrpc_mach_port_unguard_trap | MSC_macx_swapoff | MSC_pfz_exit | MSC_pfz_exit | machtrap_number_65 | machtrap_number_75 | MSC_mach_wait_until | MSC_mach_wait_until | MSC_mach_timebase_info_trap)))
(deny syscall-mig
	(require-not (cc 68d3 a523 4b30)))
(deny system-fcntl
	(require-not (fcntl-command-bitmask-regex F_WRLCK | fnctl_number_41 | fnctl_number_49 | fnctl_number_49 | fnctl_number_58 | F_SETLK64 | F_SETLKW64 | fnctl_number_82 | fnctl_number_91 | fnctl_number_91 | fnctl_number_90 | fnctl_number_99 | fnctl_number_97)))
(deny system-kas-info)
(deny system-mac-syscall
	(mac-syscall-number 96)
	(mac-policy-name "AMFI")
	(mac-syscall-number 95)
	(mac-syscall-number 102)
	(mac-syscall-number 90)
	(require-all
		(mac-policy-name "Sandbox")
		(require-not (mac-syscall-number-bitmask-regex mac_syscall_number_2 | mac_syscall_number_3))
		(mac-syscall-number 4)
		(mac-syscall-number 2)
		(mac-syscall-number 67))
	(require-all
		(mac-syscall-number 1)
		(mac-policy-name "vnguard")))
(deny system-necp-client-action)
(deny storage-class-map)
