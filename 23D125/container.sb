(delegate (with no-report) ipc*)
(delegate (with no-report) ipc-posix*)
(allow ipc-posix-sem*
	(extension com.apple.sandbox.application-group))
(allow ipc-posix-sem-create
	(semaphore-owner self))
(allow ipc-posix-shm-read-data
	(ipc-posix-name "/com.apple.AppSSO.version")
	(ipc-posix-name)
	(require-all
		(ipc-posix-name "AppleABL.")
		(entitlement-is-bool-true inter-app-audio)
		(ipc-posix-name-regex #"^AppleABL[.]." #"^AppleABL[.].+"))
	(require-all
		(ipc-posix-name "apple.shm.notification_center")
		(require-not (entitlement-is-bool-true com.apple.security.on-demand-install-capable))))
(allow ipc-posix-shm-write-create
	(ipc-posix-name))
(allow ipc-posix-shm-write-data
	(ipc-posix-name)
	(require-all
		(ipc-posix-name "AppleABL.")
		(ipc-posix-name-regex #"^AppleABL[.]." #"^AppleABL[.].+")
		(entitlement-is-bool-true inter-app-audio)))
