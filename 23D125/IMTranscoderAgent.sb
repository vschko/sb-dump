		(require-any
			(subpath-prefix "${HOME}/Library/Caches/com.apple.MobileSMS")
			(subpath-prefix "${HOME}/Library/Caches/com.apple.imtranscoding.IMTranscoderAgent")
			(vnode-type DIRECTORY)
