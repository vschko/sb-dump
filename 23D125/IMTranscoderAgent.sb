(delegate (with no-report) file-search)
(allow file-test-existence)
(delegate (with no-report) file-unmount)
(allow file-write*
	(subpath "/private/var/tmp/com.apple.messages")
	(subpath-prefix "${HOME}/Library/SMS/Attachments")
	(subpath-prefix "${HOME}/Library/Caches/com.apple.avatar")
	(subpath-prefix "${PROCESS_TEMP_DIR}/com.apple.messages")
