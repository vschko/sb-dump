(require-not (iokit-user-client-class "IOUserEthernetResource"))
(require-not (iokit-user-client-class "AppleConvergedIPCOLYBTControl")))
		(require-not (iokit-user-client-class "IOPMrootDomain"))
		(require-not (iokit-user-client-class "AppleSPUFastpathDriver"))
		(iokit-user-client-class "AGXAccelerator")))
(deny iokit-set-properties
