			(literal "/private/var/preferences/com.apple.networkextension.uuidcache.plist")
			(literal "/private/var/Managed Preferences/mobile/com.apple.SystemConfiguration.plist")
			(literal "/private/var/preferences/com.apple.security.plist")
			(require-all
				(subpath-prefix "${HOME}")
				(regex #"^/private/var/mobile/Library/Caches/com.apple.notes..+.lock$" #"^/private/var/euser[0-9]+/Library/Caches/com.apple.notes..+.lock$" #"^/private/var/[-0-9A-F]+/Library/Caches/com.apple.notes..+.lock$" #"^/private/var/Users/[^/]+/Library/Caches/com.apple.notes..+.lock$"))
			(require-all
				(subpath-prefix "${FRONT_USER_HOME}")
				(regex #"^/private/var/mobile/Library/Logs/CrashReporter/DataAccess$" #"^/private/var/mobile/Library/Logs/CrashReporter/DataAccess/" #"^/private/var/mobile/Library/Logs/CrashReporter/Retired/DataAccess$" #"^/private/var/mobile/Library/Logs/CrashReporter/Retired/DataAccess/" #"^/private/var/mobile/Library/Logs/CrashReporter/[.]DataAccess$" #"^/private/var/mobile/Library/Logs/CrashReporter/[.]DataAccess/" #"^/private/var/mobile/Library/Logs/CrashReporter/Retired/[.]DataAccess$" #"^/private/var/mobile/Library/Logs/CrashReporter/Retired/[.]DataAccess/" #"^/private/var/euser[0-9]+/Library/Logs/CrashReporter/(((Retired/)?|[.])|Retired/[.])DataAccess$" #"^/private/var/euser[0-9]+/Library/Logs/CrashReporter/(((Retired/)?|[.])|Retired/[.])DataAccess/" #"^/private/var/[-0-9A-F]+/Library/Logs/CrashReporter/(((Retired/)?|[.])|Retired/[.])DataAccess$" #"^/private/var/[-0-9A-F]+/Library/Logs/CrashReporter/(((Retired/)?|[.])|Retired/[.])DataAccess/" #"^/private/var/Users/[^/]+/Library/Logs/CrashReporter/(((Retired/)?|[.])|Retired/[.])DataAccess$" #"^/private/var/Users/[^/]+/Library/Logs/CrashReporter/(((Retired/)?|[.])|Retired/[.])DataAccess/"))))
