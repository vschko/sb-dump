(subpath-prefix "${HOME}/Library/HTTPStorages/com.apple.exchangesyncd"))
	(subpath "/AppleInternal/Library/Frameworks")
	(literal "/private/var/db/com.apple.networkextension.tracker-info")
	(require-any (literal "/private/var/Managed Preferences/mobile/.GlobalPreferences.plist")
(literal-prefix "${HOME}/Library/Safari/com.apple.Bookmarks.lock")
(literal-prefix "${HOME}/Library/Safari/BookmarksSyncMetadata.plist")
(literal-prefix "${HOME}/Library/Preferences/com.apple.dataaccess.activesync"))
	(subpath "/private/var/tmp")
	(subpath-prefix "${HOME}/Library/DataAccess")
	(subpath-prefix "${HOME}/Library/Caches/DataAccess")
	(literal-prefix "${HOME}/Library/Preferences/com.apple.dataaccess.launchd")
