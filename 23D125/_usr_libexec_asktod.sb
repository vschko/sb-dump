(version 1)
(allow default)
(deny generic-issue-extension)
(deny iokit-issue-extension)
(deny iokit-open-service
	(require-all
		(require-not (iokit-user-client-class "IOSurfaceRoot"))
		(require-not (iokit-user-client-class "AppleVideoToolboxParavirtualizationDriver"))
		(require-not (iokit-user-client-class "AppleJPEGDriver"))
		(iokit-user-client-class "AGXAccelerator")))
(deny iokit-set-properties)
(deny ipc*)
(deny ipc-posix*)
(deny ipc-posix-sem*)
(deny ipc-posix-sem-create)
(deny ipc-posix-sem-open)
(deny ipc-posix-sem-post)
(deny ipc-posix-sem-unlink)
(deny ipc-posix-sem-wait)
(deny ipc-posix-shm*)
(deny ipc-posix-shm-write*)
(deny ipc-posix-shm-write-create)
(deny ipc-posix-shm-write-data)
(deny ipc-posix-shm-write-unlink)
(deny ipc-sysv*)
(deny ipc-sysv-msg)
(deny ipc-sysv-sem)
(deny ipc-sysv-shm)
(deny job-creation)
(deny mach-issue-extension)
(deny mach-lookup
	(require-all
		(require-not (global-name "com.apple.diagnosticd"))
		(require-not (global-name "com.apple.fairplayd.versioned"))
		(require-not (global-name "com.apple.dmd.emergency-mode"))
		(require-all (require-not (global-name "com.apple.askto.client."))
(require-not (global-name "com.apple.ScreenTimeAgent.ask"))
(require-not (global-name "com.apple.contactsd.commlimits"))
(require-not (global-name "com.apple.AskToAngel.sessions"))
(require-not (global-name "com.apple.AskToTestApp"))
(require-not (global-name "com.apple.AskToTestDaemon.topic1"))
(require-not (global-name "com.apple.AskToTestDaemon.topic2"))
(require-not (global-name "com.apple.AskToTestDaemon.topicsListener")))
		(require-any
			(require-all
				(xpc-service-name-regex #".+")
				(require-not (xpc-service-name "com.apple.extensionkitservice"))
				(require-not (extension com.apple.pluginkit.plugin-service)))
			(require-all
				(require-not (global-name "com.apple.lsd.icons"))
				(require-not (global-name "com.apple.logd.events"))
				(require-not (global-name "com.apple.telephonyutilities.callservicesdaemon.conversationmanager"))
				(require-not (global-name "com.apple.runningboard"))
				(require-not (global-name "com.apple.commcenter.xpc"))
				(require-not (global-name "com.apple.identityservicesd.idquery.embedded.auth"))
				(require-not (global-name "com.apple.lsd.xpc"))
				(require-not (global-name "com.apple.ScreenTimeAgent.communication"))
				(require-not (global-name "com.apple.contactsd"))
				(require-not (global-name "com.apple.system.notification_center"))
				(require-not (xpc-service-name "com.apple.AudioAccessoryAssetManagementXPCService"))
				(require-not (global-name "com.apple.StatusKit.subscribe"))
				(require-not (global-name "com.apple.ScreenTimeAgent.private"))
				(require-not (global-name "com.apple.CARenderServer"))
				(require-not (global-name "com.apple.gpumemd.source"))
				(require-not (global-name "com.apple.contacts.poster.api"))
				(require-not (global-name "com.apple.dmd.policy"))
				(require-not (global-name "com.apple.familycircle.agent"))
				(require-not (global-name "com.apple.iconservices"))
				(require-not (global-name "com.apple.trustd"))
				(require-not (global-name "com.apple.adid"))
				(require-not (global-name "com.apple.coreservices.lsuseractivitymanager.xpc"))
				(require-not (global-name "com.apple.analyticsd"))
				(require-not (global-name "com.apple.remindd"))
				(require-not (global-name "com.apple.telephonyutilities.callservicesdaemon.callstatecontroller"))
				(require-not (xpc-service-name "com.apple.imdpersistence.IMDPersistenceAgent"))
				(require-not (global-name "com.apple.xpc.amsengagementd"))
				(require-not (global-name "com.apple.translationd"))
				(require-not (global-name "com.apple.businessservicesd"))
				(require-not (global-name "com.apple.synapse.backlink-service"))
				(require-not (global-name "com.apple.people.agent"))
				(require-not (global-name "com.apple.coreduetd.people"))
				(require-not (global-name "com.apple.spotlight.IndexAgent"))
				(require-not (xpc-service-name "com.apple.PeopleMessageService.LegacyMessageService"))
				(require-not (global-name "com.apple.inputanalyticsd"))
				(require-not (global-name "com.apple.ManagedSettingsAgent.publisher"))
				(require-not (global-name "com.apple.mobilegestalt.xpc"))
				(require-not (global-name "com.apple.cfprefsd.daemon"))
				(require-not (global-name "com.apple.webprivacyd"))
				(require-not (global-name "com.apple.symptom_diagnostics"))
				(require-not (global-name "com.apple.lsd.mapdb"))
				(require-not (global-name "com.apple.identityservicesd.embedded.auth"))
				(require-not (global-name "com.apple.privacyaccountingd"))
				(require-not (global-name "com.apple.distributed_notifications@1v3"))
				(require-not (global-name "com.apple.geod"))
				(require-not (global-name "com.apple.imagent.embedded.auth"))
				(require-not (global-name "com.apple.family.ageRange.xpc"))
				(require-not (global-name "com.apple.corerecents.recentsd"))
				(require-not (global-name "com.apple.logd"))
				(require-not (global-name "com.apple.assistant.settings"))
				(require-not (global-name "com.apple.linkd.autoShortcut"))
				(require-not (global-name "com.apple.telephonyutilities.callservicesdaemon.callcapabilities"))
				(require-not (global-name "com.apple.contacts.CNContactsTestsEnvironmentServer"))
				(require-not (global-name "com.apple.tccd"))
				(require-not (xpc-service-name "com.apple.intents.intents-helper"))
				(require-not (global-name "com.apple.commcenter.coretelephony.xpc"))
				(require-not (global-name "com.apple.containermanagerd"))
				(require-not (global-name "com.apple.usernotifications.listener"))
				(require-not (global-name "com.apple.cfprefsd.daemon.system"))
				(require-not (global-name "com.apple.containermanagerd.system"))
				(require-not (global-name "com.apple.frontboard.systemappservices"))
				(global-name "com.apple.ABDatabaseDoctor")))))
(deny process-exec*)
(deny process-exec-interpreter)
(deny socket-ioctl
	(require-all
		(require-not (ioctl-command-regex [UNSUPPORTED](_IO "i" 218)))
		(ioctl-command-regex [UNSUPPORTED](_IO "i" 51))
		(ioctl-command-regex [UNSUPPORTED](_IO "i" 160))
		(ioctl-command-regex [UNSUPPORTED](_IO "i" 17))
		(ioctl-command-regex [UNSUPPORTED](_IO "i" 173))
		(ioctl-command-regex [UNSUPPORTED](_IO "i" 157))
		(ioctl-command-regex [UNSUPPORTED](_IO "i" 204))))
(deny syscall-unix
	(require-not (syscall-number-bitmask-regex exit | read | write | open | sys_close | getfsstat | getpid | getuid | geteuid | recvmsg | sendmsg | recvfrom | access | sys_crossarch_trap | sys_dup | getegid | sigaction | getgid | sigprocmask | sigpending | sigaltstack | ioctl | readlink | munmap | mprotect | madvise | sys_dup2 | sys_fcntl | select | fsync | socket | connect | sigsuspend | gettimeofday | readv | writev | rename | sendto | shutdown | mkdir | rmdir | pread | pwrite | statfs | fstatfs | csops | csops_audittoken | kdebug_typefilter | kdebug_trace_string | kdebug_trace64 | kdebug_trace | sigreturn | stat | sys_fstat | lstat | pathconf | getrlimit | setrlimit | mmap | lseek | ftruncate | sysctl | open_dprotected_np | openat_dprotected_np | getattrlist | fgetattrlist | listxattr | fsctl | shm_open | sys_sysctlbyname | stat_extended | lstat_extended | sys_fstat_extended | gettid | mkdir_extended | shared_region_check_np | psynch_rw_longrdlock | psynch_rw_yieldwrlock | psynch_rw_downgrade | psynch_rw_upgrade | psynch_mutexwait | psynch_mutexdrop | psynch_cvbroad | psynch_cvsignal | psynch_cvwait | psynch_rw_rdlock | psynch_rw_wrlock | psynch_rw_unlock | psynch_rw_unlock2 | psynch_cvclrprepost | issetugid | __pthread_kill | __pthread_sigmask | __sigwait | __disable_threadsignal | __pthread_markcancel | __pthread_canceled | proc_info | stat64 | sys_fstat64 | lstat64 | stat64_extended | lstat64_extended | sys_fstat64_extended | getdirentries64 | statfs64 | fstatfs64 | getfsstat64 | __pthread_chdir | __pthread_fchdir | bsdthread_create | bsdthread_terminate | kqueue | kevent | bsdthread_register | workq_open | workq_kernreturn | kevent64 | kevent_qos | kevent_id | __mac_syscall | pselect | pselect_nocancel | read_nocancel | write_nocancel | open_nocancel | sys_close_nocancel | recvmsg_nocancel | sendmsg_nocancel | recvfrom_nocancel | sys_fcntl_nocancel | select_nocancel | fsync_nocancel | connect_nocancel | sigsuspend_nocancel | readv_nocancel | writev_nocancel | sendto_nocancel | pread_nocancel | pwrite_nocancel | __sigwait_nocancel | fsgetpath | sys_fileport_makeport | sys_fileport_makefd | memorystatus_control | guarded_open_np | guarded_close_np | guarded_kqueue_np | change_fdguard_np | proc_rlimit_control | openat | faccessat | fstatat | fstatat64 | mkdirat | bsdthread_ctl | guarded_open_dprotected_np | guarded_write_np | guarded_pwrite_np | guarded_writev_np | persona | getentropy | necp_open | necp_client_action | __nexus_set_opt | sys_ulock_wait | sys_ulock_wake | abort_with_payload | kqueue_workloop_ctl | memorystatus_available_memory | objc_bp_assist_cfg_np | sys_preadv | sys_pwritev | sys_preadv_nocancel | sys_pwritev_nocancel | sys_ulock_wait2 | proc_info_extended_id | map_with_linking_np)))
(deny syscall-mach
	(require-not (machtrap-number-bitmask-regex MSC__kernelrpc_mach_vm_purgable_control_trap | MSC__kernelrpc_mach_vm_purgable_control_trap | MSC__kernelrpc_mach_vm_purgable_control_trap | machtrap_number_17 | MSC__kernelrpc_mach_port_mod_refs_trap | MSC__kernelrpc_mach_port_deallocate_trap | MSC__kernelrpc_mach_port_mod_refs_trap | MSC_thread_self_trap | MSC_thread_self_trap | MSC_thread_self_trap | MSC_semaphore_signal_all_trap | MSC_semaphore_signal_trap | MSC_semaphore_signal_trap | MSC_mach_generate_activity_id | MSC__kernelrpc_mach_port_unguard_trap | MSC__kernelrpc_mach_port_guard_trap | MSC_mach_generate_activity_id | MSC_macx_swapoff | MSC_pfz_exit | machtrap_number_65 | machtrap_number_75 | MSC_mach_wait_until | MSC_mach_wait_until | MSC_mk_timer_create | MSC_mach_timebase_info_trap)))
(deny syscall-mig
	(require-not (cc 1ab7 a523 95f9)))
(deny system-fcntl
	(require-not (fcntl-command-bitmask-regex F_UNLCK | F_WRLCK | F_RDLCK | fnctl_number_41 | fnctl_number_49 | fnctl_number_49 | fnctl_number_58 | F_SETLK64 | F_SETLKW64 | fnctl_number_82 | fnctl_number_91 | fnctl_number_98 | fnctl_number_97)))
(deny system-kas-info)
(deny storage-class-map)
