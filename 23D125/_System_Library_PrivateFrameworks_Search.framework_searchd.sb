		(require-not (fsctl-command-regex [UNSUPPORTED](_IO "J" 106)))
		(require-not (fsctl-command-regex [UNSUPPORTED](_IO "J" 32)))
		(require-not (fsctl-command-regex [UNSUPPORTED](_IO "J" 90)))))
(deny system-kas-info)
(deny storage-class-map)
